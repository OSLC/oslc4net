{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../OSLC4Net_SDK/",
          "files": [
            "OSLC4Net.Core/OSLC4Net.Core.csproj",
            "OSLC4Net.Core.DotNetRdfProvider/OSLC4Net.Core.DotNetRdfProvider.csproj",
            "OSLC4Net.Core.Query/OSLC4Net.Core.Query.csproj",
            "OSLC4Net.Client/OSLC4Net.Client.csproj",
            "OSLC4Net.Server.Providers/OSLC4Net.Server.Providers.csproj",
            "OSLC4Net.CodeGen/OSLC4Net.CodeGen.csproj",
            "OSLC4Net.Domains.ArchitectureManagement/OSLC4Net.Domains.ArchitectureManagement.csproj",
            "OSLC4Net.Domains.Automation/OSLC4Net.Domains.Automation.csproj",
            "OSLC4Net.Domains.ChangeManagement/OSLC4Net.Domains.ChangeManagement.csproj",
            "OSLC4Net.Domains.ConfigurationManagement/OSLC4Net.Domains.ConfigurationManagement.csproj",
            "OSLC4Net.Domains.KerML/OSLC4Net.Domains.KerML.csproj",
            "OSLC4Net.Domains.QualityManagement/OSLC4Net.Domains.QualityManagement.csproj",
            "OSLC4Net.Domains.RequirementsManagement/OSLC4Net.Domains.RequirementsManagement.csproj",
            "OSLC4Net.Domains.SysMLV2/OSLC4Net.Domains.SysMLV2.csproj",
            "OSLC4Net.Domains.TrackedResourceSet/OSLC4Net.Domains.TrackedResourceSet.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "template"
    ],
    "globalMetadata": {
      "_appName": "OSLC4Net",
      "_appTitle": "OSLC4Net",
      "_appLogoPath": "images/logo_docfx.png",
      "_appFaviconPath": "images/favicon.ico",
      "_appFooter": "<script defer src=\"https://umami.open-services.net/script.js\" data-website-id=\"058571d1-b69b-4b21-a24a-2cc26e4eb3e1\"></script>",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
